{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "core.intent.flow.schema.json",
    "title": "CORE Flow Declaration",
    "description": "Constitutional declaration of a Flow. Existence in .intent/flows/ is the sole source of constitutional standing for a Flow.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "kind",
        "metadata",
        "flow"
    ],
    "properties": {
        "$schema": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
        },
        "kind": {
            "type": "string",
            "enum": [
                "flow"
            ]
        },
        "metadata": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "id",
                "title",
                "version",
                "authority",
                "status"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 128,
                    "description": "Unique identifier. e.g. flows.fix_code"
                },
                "title": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 256
                },
                "version": {
                    "type": "string",
                    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
                },
                "authority": {
                    "type": "string",
                    "enum": [
                        "policy",
                        "code"
                    ],
                    "description": "Flows operate at policy or code authority. Never meta or constitution."
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "active",
                        "paused",
                        "deprecated"
                    ]
                },
                "rationale": {
                    "type": "string",
                    "maxLength": 1000,
                    "description": "Human-readable explanation of status decisions."
                }
            }
        },
        "flow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "flow_id",
                "description",
                "steps",
                "policies"
            ],
            "properties": {
                "flow_id": {
                    "type": "string",
                    "pattern": "^flow\\.[a-z0-9_.]+$",
                    "description": "Unique dot-notation identifier. Must begin with 'flow.'. e.g. flow.fix_code"
                },
                "description": {
                    "type": "string",
                    "minLength": 10,
                    "maxLength": 512,
                    "description": "One sentence describing what this Flow does."
                },
                "policies": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string"
                    },
                    "description": "Policy IDs governing this Flow."
                },
                "steps": {
                    "type": "array",
                    "minItems": 1,
                    "description": "Ordered sequence of steps. Executed top to bottom.",
                    "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": [
                            "ref_id",
                            "kind"
                        ],
                        "properties": {
                            "ref_id": {
                                "type": "string",
                                "minLength": 3,
                                "description": "action_id or flow_id this step resolves to."
                            },
                            "kind": {
                                "type": "string",
                                "enum": [
                                    "action",
                                    "flow"
                                ],
                                "description": "Whether ref_id is an AtomicAction or a nested Flow."
                            },
                            "required": {
                                "type": "boolean",
                                "default": true,
                                "description": "If true, failure halts the Flow. If false, failure is recorded and execution continues."
                            },
                            "params": {
                                "type": "object",
                                "description": "Static parameters passed to this step. Caller params override these."
                            },
                            "consumes": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "description": "Allowlist of caller param keys forwarded to this step. Absent means current executor default (see issue #445)."
                            }
                        }
                    }
                }
            }
        }
    }
}
