{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CORE Workflow Definition Schema",
  "description": "Schema for workflow definitions that compose phase-bound workflow stages in CORE.",
  "type": "object",
  "additionalProperties": false,

  "properties": {

    "$schema": {
      "type": "string",
      "minLength": 1
    },

    "kind": {
      "type": "string",
      "const": "workflow_definition"
    },

    "workflow_id": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+$"
    },

    "version": {
      "type": "string"
    },

    "status": {
      "$ref": "./enums.json#/definitions/artifact_status"
    },

    "description": {
      "type": "string",
      "minLength": 5
    },

    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "stage_id": {
            "type": "string",
            "pattern": "^[a-z0-9_.-]+$"
          },
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "conditional": {
            "type": "string"
          }
        },
        "required": [
          "stage_id",
          "order"
        ]
      }
    },

    "invariants": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "must_hold": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_not": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }

  },

  "required": [
    "workflow_id",
    "description",
    "stages"
  ]
}
